PORT=8787
HOST=127.0.0.1
CLIENT_ORIGIN=http://localhost:3000

# ── AI model ──────────────────────────────────────────────────────────────────
# ANNA_API_KEY is the ONLY required field.
# Without it the server uses a reliable built-in template fallback.
ANNA_API_KEY=your-key-here

# ANNA_API_URL — base URL *or* full chat-completions URL.
# The agent auto-appends /v1/chat/completions if the path is missing.
#
# Examples:
#   OpenAI standard:    https://api.openai.com/v1/chat/completions
#   Anna AI Nexus:      https://nexus.anna.ai          (path is added automatically)
#   Any OpenAI proxy:   https://your-proxy.example.com
#
# Defaults to OpenAI if not set.
ANNA_API_URL=https://api.openai.com/v1/chat/completions

# Model to use — defaults to gpt-4o if not set.
ANNA_MODEL=gpt-4o
